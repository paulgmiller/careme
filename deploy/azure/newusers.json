    "name": "new users",
    "type": "microsoft.insights/scheduledqueryrules",
    "kind": "LogAlert",
    "location": "westus3",
    "tags": {},
    "properties": {
        "createdWithApiVersion": "2025-01-01-preview",
        "displayName": "new users",
        "description": "people signed up!",
        "severity": 3,
        "enabled": true,
        "evaluationFrequency": "P1D",
        "scopes": [
