        "targetResourceTypes": [
            "microsoft.insights/components"
        ],
        "windowSize": "P1D",
        "overrideQueryTimeRange": "P2D",
        "criteria": {
            "allOf": [
                {
                    "query": "traces\n| where timestamp > ago(1d)\n| where message startswith \"created new user\"\n",
                    "timeAggregation": "Count",
                    "dimensions": [],
                    "resourceIdColumn": "",
                    "operator": "GreaterThan",
                    "threshold": 0,
                    "failingPeriods": {
                        "numberOfEvaluationPeriods": 1,
                        "minFailingPeriodsToAlert": 1
                    }
                }
            ]
        },
        "autoMitigate": false,
        "actions": {
            "actionGroups": [
