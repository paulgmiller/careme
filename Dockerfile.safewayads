# Multi-stage build for the Safeway weekly-ad batch job
FROM golang:1.24-alpine AS builder
WORKDIR /src

COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN go test ./... -count=1
RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build -ldflags="-s -w" -o safewayads ./cmd/safewayads

FROM alpine:3.22
RUN apk add --no-cache ca-certificates poppler-utils
WORKDIR /workspace
COPY --from=builder /src/safewayads /safewayads
USER 65532:65532
ENTRYPOINT ["/safewayads"]
